    "configuration": {
      "title": "GenieOps",
      "properties": {
        "genieops.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable anonymous usage telemetry (opt-in only, GDPR compliant)"
        },
        "genieops.autoAnalyzeProject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyze project context on workspace open"
        },
        "genieops.showProgressNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show streaming progress for all operations"
        },
        "genieops.models.claude.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Claude 3.5 Sonnet (Anthropic) - Primary model for code generation"
        },
        "genieops.models.claude.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (stored securely in VS Code secret storage)"
        },
        "genieops.models.openai.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable GPT-4o (OpenAI) - Secondary model for alternative implementations"
        },
        "genieops.models.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key"
        },
        "genieops.models.gemini.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Gemini Pro (Google) - For GCP tasks and multimodal analysis"
        },
        "genieops.models.gemini.apiKey": {
          "type": "string",
          "default": "",
          "description": "Google AI Studio API key"
        },
        "genieops.models.geminiFlash.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Gemini Flash - Fast completions and autocomplete"
        },
        "genieops.models.mistral.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Mistral - Local/private completions"
        },
        "genieops.models.perplexity.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Perplexity - Real-time web search for trending best practices"
        },
        "genieops.models.perplexity.apiKey": {
          "type": "string",
          "default": "",
          "description": "Perplexity API key"
        },
        "genieops.parallelExecution.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run multiple AI models in parallel (Model Race Mode)"
        },
        "genieops.parallelExecution.showComparison": {
          "type": "boolean",
          "default": true,
          "description": "Show side-by-side comparison when multiple models answer"
        },
        "genieops.costEstimation.showBeforeProvisioning": {
          "type": "boolean",
          "default": true,
          "description": "Show estimated monthly cost before provisioning cloud resources"
        },
        "genieops.rollback.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable undo/rollback for all operations"
        },
        "genieops.secrets.syncToVault": {
          "type": "boolean",
          "default": false,
          "description": "Auto-sync secrets to external vault (Doppler/AWS Secrets Manager)"
        },
        "genieops.secrets.vaultProvider": {
          "type": "string",
          "enum": [
            "none",
            "doppler",
            "aws-secrets-manager",
            "hashicorp-vault"
          ],
          "default": "none",
          "description": "External secrets vault provider"
        },
        "genieops.docker.preferredRegistry": {
          "type": "string",
          "enum": [
            "dockerhub",
            "ecr",
            "gcr",
            "ghcr"
          ],
          "default": "dockerhub",
          "description": "Preferred Docker registry for image pushes"
        },
        "genieops.cicd.preferredProvider": {
          "type": "string",
          "enum": [
            "github-actions",
            "gitlab-ci",
            "jenkins",
            "bitbucket-pipelines"
          ],
          "default": "github-actions",
          "description": "Preferred CI/CD provider"
        },
        "genieops.kubernetes.defaultClusterType": {
          "type": "string",
          "enum": [
            "eks",
            "gke",
            "aks",
            "minikube",
            "k3s",
            "kind"
          ],
          "default": "eks",
          "description": "Default Kubernetes cluster type for new deployments"
        },
        "genieops.packageManager.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect package manager (npm/yarn/pnpm/bun)"
        },
        "genieops.env.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update .env file with new credentials"
        },
        "genieops.env.addToGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add .env to .gitignore"
        },
        "genieops.notifications.slack.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Send deployment notifications to Slack"
        },
        "genieops.notifications.discord.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Send deployment notifications to Discord"
        }
      }
    },
    "keybindings": [
      {
        "command": "genieops.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorTextFocus"
      },
      {
        "command": "genieops.runCommand",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "genieops.vibeCode",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "genieops.openChat",
          "when": "true"
        },
        {
          "command": "genieops.runCommand",
          "when": "true"
        },
        {
          "command": "genieops.vibeCode",
          "when": "true"
        }
      ],
      "view/title": [
        {
          "command": "genieops.refreshConnections",
          "when": "view == genieops.connectionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "genieops.disconnectService",
          "when": "view == genieops.connectionsView && viewItem == connectedService",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
